meta {
  name: 8 - Update Achievement
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/api/profile/achievements/1
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "title": "MPL Champion S12",
    "description": "Won the MPL S12 with 3-0 score",
    "year": 2026,
    "image_url": "https://example.com/badge.png"
  }
}
