meta {
  name: 7 - Create Achievement
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/profile/achievements
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "title": "MPL Champion",
    "description": "Won the MPL S12",
    "year": 2026,
    "image_url": "https://example.com/badge.png"
  }
}
